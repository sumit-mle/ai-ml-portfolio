# Template — safe to commit. Copy to .env and fill in real values.

# OpenAI
OPENAI_API_KEY=
GEN_MODEL=gpt-4o-mini
EXTRACT_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# Neo4j (defaults match docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag-pass
NEO4J_DATABASE=neo4j

# SEC EDGAR — required by SEC's fair-use policy
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=GraphRAG-Demo your.email@example.com

DATA_DIR=./data
