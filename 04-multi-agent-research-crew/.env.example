# Template — safe to commit. Copy to .env and fill in real values.

# OpenAI
OPENAI_API_KEY=
GEN_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini

# Tavily — web search and news (free tier: 1000 calls/month)
# https://tavily.com/  (sign up for an API key)
TAVILY_API_KEY=

# SEC EDGAR — required by SEC fair-use policy
SEC_USER_AGENT=SalesResearch-Demo your.email@example.com

# CrewAI telemetry (off by default — explicit opt-in)
OTEL_SDK_DISABLED=true
CREWAI_TRACING_ENABLED=false

# Output
OUTPUT_DIR=./output
