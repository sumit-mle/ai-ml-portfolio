# Template — safe to commit. Copy to .env and fill in real values.

# OpenAI
OPENAI_API_KEY=
REALTIME_MODEL=gpt-realtime
GEN_MODEL=gpt-4o-mini             # used by the text-mode eval runner
JUDGE_MODEL=gpt-4o-mini

# Server
HOST=127.0.0.1
PORT=7777

# Backend store
DB_PATH=./data/helpdesk.sqlite
DATA_DIR=./data

# Audit log path (JSONL, one event per line)
AUDIT_LOG_PATH=./logs/audit.jsonl

# Identity verification policy
# Privileged tools (unlock_account, reset_password) require verified identity.
# Verification = correct employee_id + last 4 of phone on file.
REQUIRE_IDENTITY_VERIFICATION=true
