# Template — safe to commit. Copy to .env and fill in real values.

# OpenAI (autonomous agent path)
OPENAI_API_KEY=
GEN_MODEL=gpt-4o-mini

# Self-hosted compliance portal (used by the demo)
PORTAL_HOST=127.0.0.1
PORTAL_PORT=7878
PORTAL_BASE_URL=http://127.0.0.1:7878

# Vendor allowlist — comma-separated. The agent will REFUSE to navigate to
# any host not in this list. Production deployments should keep this tight.
ALLOWED_HOSTS=127.0.0.1,localhost

# Output paths
DATA_DIR=./data
EVIDENCE_DIR=./output/evidence
AUDIT_LOG_PATH=./logs/audit.jsonl
SCREENSHOT_DIR=./output/screenshots

# Browser settings
HEADLESS=true
BROWSER_TIMEOUT_S=30

# Agent guardrails
AGENT_MAX_STEPS=25
