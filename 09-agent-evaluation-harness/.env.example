# Template — safe to commit. Copy to .env and fill in real values.

# OpenAI (used by the LLM-as-judge for faithfulness)
OPENAI_API_KEY=
JUDGE_MODEL=gpt-4o-mini

# Path to project 01 (the System Under Test). Default assumes sibling layout.
PROJECT_01_PATH=../01-contract-review-rag

# Output paths
RESULTS_DIR=./results
BASELINES_DIR=./baselines
REPORTS_DIR=./reports

# Regression thresholds — used by `harness gate` to fail CI.
# A current-run metric must be at most this much below the baseline before
# we call it a regression.
REGRESSION_TOLERANCE_FAITHFULNESS=0.05
REGRESSION_TOLERANCE_CITATION=0.05
REGRESSION_TOLERANCE_CLAUSE_MATCH=0.05
