# Template — safe to commit. Copy to .env and fill in real values.

# OpenAI (only used by the NL->SQL tool, which is optional)
OPENAI_API_KEY=
GEN_MODEL=gpt-4o-mini

# Server
SERVER_NAME=enterprise-data-platform
SERVER_VERSION=0.1.0
TRANSPORT=stdio                 # stdio | http
HTTP_HOST=127.0.0.1
HTTP_PORT=7878

# Database
DUCKDB_PATH=./data/warehouse.duckdb
DATA_DIR=./data
PARQUET_DIR=./data/parquet

# Auth — comma-separated `token:scope1,scope2` triples per line. We load the
# matching tokens at startup. Real deployments would use OAuth/OIDC; for the
# demo this is a static-token equivalent (read-only API key style).
# Each scope grants access to a specific tool subset.
AUTH_TOKEN_FILE=./auth/tokens.json

# Limits
QUERY_TIMEOUT_S=30
MAX_ROWS_RETURNED=10000
RATE_LIMIT_PER_HOUR=100         # per token, queries/hour

# Audit log path (JSONL, one event per line)
AUDIT_LOG_PATH=./logs/audit.jsonl
