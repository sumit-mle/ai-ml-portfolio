# Template — safe to commit. Copy to .env and fill in real values.
OPENAI_API_KEY=
GEN_MODEL=gpt-4o-mini

# Local DuckDB warehouse (read-only at query time, write-only via init-db)
DB_PATH=./data/marketing.duckdb
DATA_DIR=./data

# Agent guardrails
MAX_REPAIR_ATTEMPTS=3
QUERY_TIMEOUT_S=15
MAX_ROWS_RETURNED=2000

# Logs
TRACE_DIR=./output/traces
RESULTS_DIR=./results
