# Template — safe to commit. Copy to .env and fill in real values.

OPENAI_API_KEY=
GEN_MODEL=gpt-4o-mini

# Risk threshold for auto-approval. low | medium | high
# Anything ABOVE this rating triggers a human-in-the-loop gate.
AUTO_APPROVE_BELOW=medium

# Output directory for audit logs and patched files
OUTPUT_DIR=./output
